<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/bootstrap.min.css">
    <script src="/bootstrap.min.js"></script>
</head>

<body>
    <nav class="p-1 px-5 w-100 bg-danger text-white"
        style="display: flex; justify-content: space-between; align-items: center; height: 50px;">
        <h3>menu</h3>
        <a class="btn btn-primary" href="/cart">cart</a>
    </nav>
    <div class="container p-3 rounded">
        <div class="row p-4 gap-3">
            <% data.forEach(function(item) { %>
                <div class="col pt-3 text-white rounded"
                    style="display: flex; flex-direction: column; min-height: 450px; min-width: 350px; background-color: rgb(235, 79, 7);">
                    <h3>
                        <%= item.name %>
                    </h3>
                    <p>
                        <%= item.description %>
                    </p>
                    <p>
                        <%= item.price %> บาท
                    </p>
                    <div class="bg-white rounded"
                        style="display: flex; justify-content: center; width: 100%; height: 230px;  ">
                        <img src="<%= item.image %>" alt="item" class="rounded"
                            style="object-position: center; object-fit: cover; width: 100%;" />
                    </div>
                    <button class="btn btn-success mt-2" style="height: 40px;"
                        onclick="shop(<%= item.id %>)">DETAIL</button>
                    <button class="btn btn-primary mt-2" style="height: 50px;"
                        onclick="cart(<%= item.id %>)">CART</button>
                </div>
                <% }); %>
        </div>
    </div>

    <script>
        function shop(params) {
            window.location = '/menu/' + params;
        };

        function cart(params) {
            window.location = '/cart/add/' + params;
        };
    </script>
</body>

</html>