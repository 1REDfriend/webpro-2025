<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/bootstrap.min.css">
    <script src="/bootstrap.min.js"></script>
</head>

<body class="px-5" style="display: flex; justify-content: center; flex-direction: column; align-items: center; ">
    <a href="/" class="btn btn-primary mt-5" style="align-self: end;"> <- Go back To Shop </a>
    <div class="rounded mt-3 p-4"
        style="display: flex; justify-content: center; width: 70vw; background-color: rgb(57, 65, 71); color: white; min-height: 80vh;">
        <div style="display: flex; justify-content: center; align-items: start;">
            <% if (data) { %>
                <table class="table text-white">
                    <thead>
                        <tr>
                            <th scope="col">Name</th>
                            <th scope="col">Description</th>
                            <th scope="col">Price</th>
                            <th scope="col">Options</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% data.forEach(function(items) { %>
                            <tr>
                                <td> <%= items.menu_name %> </td>
                                <td> <%= items.menu_description %> </td>
                                <td> <%= items.menu_price %> </td>
                                <td>
                                    <button onclick="remove(<%= items.id %>)" class="btn btn-danger">DELETE</button>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p> No data on this your cart right now.</p>
            <% } %>
        </div>
    </div>

    <script>
        function remove(param) { 
            window.location = `/cart/delete/${param}`
         }
    </script>
</body>

</html>