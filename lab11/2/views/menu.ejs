<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <title>AUNTIE-AUN Restaurant - Menu</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background-color: #f5f5f5;
        }

        .navbar {
            background-color: #1cb036;
            padding: 15px;
            text-align: center;
            color: white;
        }

        .navbar a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
            font-size: 18px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }

        h1 {
            text-align: center;
            margin-bottom: 30px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
            display: flex;
            flex-direction: column;
        }

        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .card-body {
            padding: 15px;
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .card-title {
            font-size: 18px;
            font-weight: bold;
            margin: 0 0 10px 0;
        }

        .card-desc {
            font-size: 14px;
            color: #666;
            margin-bottom: 15px;
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .price {
            color: #d9534f;
            font-weight: bold;
        }

        .btn {
            background-color: #007bff;
            color: white;
            text-decoration: none;
            padding: 8px 15px;
            border-radius: 4px;
            border: none;
            font-size: 14px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="navbar">
        <a href="/menu">Menu</a>
        <a href="/cart">Cart</a>
    </div>

    <div class="container">
        <h1>AUNTIE-AUN Restaurant</h1>
        <div class="grid">
            <% if(foods && foods.length> 0) { %>
                <% foods.forEach(food=> { %>
                    <div class="card">
                        <img src="<%= food.image_url %>" alt="<%= food.name %>">
                        <div class="card-body">
                            <div>
                                <h3 class="card-title">
                                    <%= food.name %>
                                </h3>
                                <p class="card-desc">
                                    <%= food.description %>
                                </p>
                            </div>
                            <div class="card-footer">
                                <span class="price">
                                    <%= food.price %> THB
                                </span>
                                <a href="/add-to-cart/<%= food.product_id %>" class="btn">Add to Cart</a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                        <% } else { %>
                            <p>ไม่พบรายการอาหาร</p>
                            <% } %>
        </div>
    </div>

</body>

</html>