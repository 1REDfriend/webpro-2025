<!DOCTYPE html>
<html lang="th">

<head>
    <meta charset="UTF-8">
    <title>Cart - AUNTIE-AUN Restaurant</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            background-color: #f5f5f5;
        }

        .navbar {
            background-color: #1cb036;
            padding: 15px;
            text-align: center;
        }

        .navbar a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
            font-size: 18px;
        }

        .container {
            max-width: 800px;
            margin: 40px auto;
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th,
        td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        th {
            background-color: #f8f9fa;
        }

        .total {
            text-align: right;
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .btn-checkout {
            background-color: #28a745;
            color: white;
            text-decoration: none;
            padding: 10px 20px;
            border-radius: 4px;
            display: inline-block;
            font-weight: bold;
        }

        .btn-checkout:hover {
            background-color: #218838;
        }

        .empty-cart {
            text-align: center;
            padding: 40px;
            color: #666;
        }
    </style>
</head>

<body>

    <div class="navbar">
        <a href="/menu">Menu</a>
        <a href="/cart">Cart</a>
    </div>

    <div class="container">
        <h2>ตะกร้าสินค้าของคุณ</h2>

        <% if(cart && cart.length> 0) { %>
            <table>
                <thead>
                    <tr>
                        <th>ลำดับ</th>
                        <th>ชื่อเมนู</th>
                        <th>ราคา</th>
                    </tr>
                </thead>
                <tbody>
                    <% cart.forEach((item, index)=> { %>
                        <tr>
                            <td>
                                <%= index + 1 %>
                            </td>
                            <td>
                                <%= item.name %>
                            </td>
                            <td>
                                <%= item.price %> THB
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>

            <div class="total">
                ราคารวมทั้งหมด: <%= total %> THB
            </div>

            <div style="text-align: right;">
                <a href="/checkout" class="btn-checkout">ยืนยันการสั่งซื้อ (Checkout)</a>
            </div>
            <% } else { %>
                <div class="empty-cart">
                    <h3>ไม่มีรายการอาหารในตะกร้า</h3>
                    <br>
                    <a href="/menu" style="color: #007bff; text-decoration: none;">กลับไปเลือกเมนูอาหาร</a>
                </div>
                <% } %>
    </div>

</body>

</html>