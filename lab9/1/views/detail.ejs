<%- include('partials/header') %>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">ข้อมูลพนักงาน: <%= user.firstname %>
                    </h4>
                </div>
                <div class="card-body p-5">
                    <div class="row">
                        <div class="col-md-4 text-center mb-3">
                            <img src="https://ui-avatars.com/api/?name=<%= user.firstname %>+<%= user.lastname %>&size=150&background=random"
                                class="rounded-circle img-thumbnail shadow-sm" alt="User Image">
                        </div>

                        <div class="col-md-8">
                            <h3 class="card-title text-primary">
                                <%= user.firstname %>
                                    <%= user.lastname %>
                            </h3>
                            <p class="text-muted mb-4">
                                <%= user.position %>
                            </p>

                            <ul class="list-group list-group-flush mb-3">
                                <li class="list-group-item">
                                    <strong>รหัสพนักงาน (ID):</strong>
                                    <%= user.id %>
                                </li>
                                <li class="list-group-item">
                                    <strong>อีเมล:</strong>
                                    <%= user.email %>
                                </li>
                            </ul>

                            <div class="d-grid gap-2 d-md-block mt-4">
                                <a href="/lab9/1" class="btn btn-outline-secondary">
                                    &larr; ย้อนกลับ
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>