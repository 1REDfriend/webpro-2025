<%- include('partials/header') %>

    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="text-center mb-5">
                <h1 class="fw-bold text-primary">คลังข้อสอบ (Quiz Bank)</h1>
                <p class="text-muted">รายการคำถามทั้งหมดจากฐานข้อมูล SQLite</p>
            </div>

            <% if (questions.length> 0) { %>
                <% questions.forEach((q, index)=> { %>

                    <div class="card shadow-sm mb-4 border-start border-5 border-primary">
                        <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                            <h5 class="mb-0 fw-bold text-dark">
                                <span class="badge bg-primary me-2">ข้อที่ <%= q.QID %></span>
                                <%= q.Stem %>
                            </h5>
                        </div>

                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6 mb-2">
                                    <div
                                        class="p-2 border rounded <%= (q.Correct === 'A') ? 'bg-success text-white' : 'bg-light' %>">
                                        <strong>A.</strong>
                                        <%= q.Alt_A %>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <div
                                        class="p-2 border rounded <%= (q.Correct === 'B') ? 'bg-success text-white' : 'bg-light' %>">
                                        <strong>B.</strong>
                                        <%= q.Alt_B %>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <div
                                        class="p-2 border rounded <%= (q.Correct === 'C') ? 'bg-success text-white' : 'bg-light' %>">
                                        <strong>C.</strong>
                                        <%= q.Alt_C %>
                                    </div>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <div
                                        class="p-2 border rounded <%= (q.Correct === 'D') ? 'bg-success text-white' : 'bg-light' %>">
                                        <strong>D.</strong>
                                        <%= q.Alt_D %>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-footer text-muted text-end small">
                            เฉลย: <strong>
                                <%= q.Correct %>
                            </strong>
                        </div>
                    </div>

                    <% }) %>
                        <% } else { %>
                            <div class="alert alert-warning text-center">
                                ไม่พบข้อมูลข้อสอบในระบบ
                            </div>
                            <% } %>

        </div>
    </div>

    <%- include('partials/footer') %>