<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* กำหนดสีหัวตารางให้ตรงกับภาพตัวอย่าง */
        .table-custom-header {
            background-color: #0d6efd !important;
            /* สีน้ำเงิน Primary ของ Bootstrap */
            color: white !important;
            border-bottom: none;
        }

        /* ปรับสีพื้นหลังของหน้าเว็บเล็กน้อย */
        body {
            background-color: #f8f9fa;
        }
    </style>
</head>

<body>

    <div class="container mt-5">
        <h2 class="text-center mb-4 fw-bold text-dark">Book Store</h2>

        <div class="table-responsive shadow-sm">
            <table class="table table-striped table-hover table-bordered align-middle mb-0">
                <thead>
                    <tr>
                        <th class="table-custom-header py-3">ID</th>
                        <th class="table-custom-header py-3">Book name</th>
                        <th class="table-custom-header py-3">Description</th>
                        <th class="table-custom-header py-3">Price</th>
                        <th class="table-custom-header py-3">Amount</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    <% data.forEach((book)=> { %>
                        <tr>
                            <td>
                                <%= book.id %>
                            </td>
                            <td>
                                <%= book.name %>
                            </td>
                            <td>
                                <%= book.description %>
                            </td>
                            <td>
                                <%= book.price %>
                            </td>
                            <td>
                                <%= book.amount %>
                            </td>
                        </tr>
                        <% }); %>
                </tbody>
            </table>
        </div>
    </div>

</body>

</html>