<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Detail</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow border-0 p-4" style="max-width: 500px; width: 100%;">
        <h2 class="mb-4">Product <%= item.product_id %> Detail</h2>
        
        <img src="<%= item.image_url %>" class="img-fluid rounded mb-4" alt="<%= item.name %>">
        
        <h3 class="mb-3"><%= item.name %></h3>
        <p class="text-secondary">Description : <%= item.description %></p>
        <p class="mb-2">Price : <%= item.price %></p>
        <p class="mb-4">Amount : <%= item.quantity %></p>
        
        <div>
            <a href="/" class="btn btn-primary px-4">Go Back</a>
        </div>
    </div>
</div>

</body>
</html>